# Secrets de déploiement emule-indexer — COPIER en .env (gitignoré), renseigner les vraies valeurs.
# Le .env est lu automatiquement par `docker compose` (variables ${...} de compose.yaml).

# --- gluetun (VPN WireGuard) ---
# Le port forwarding gluetun (requis pour un High-ID joignable) n'existe QUE pour 4 providers :
# ProtonVPN, PIA, PrivateVPN, PerfectPrivacy. Avec un autre provider, on tourne en Low-ID (ou il
# faut ouvrir/rediriger un port soi-même). VPN_SERVICE_PROVIDER se règle dans compose.yaml ;
# adaptez les variables ci-dessous au provider choisi (ici : exemple WireGuard).
WIREGUARD_PRIVATE_KEY=changeme-wireguard-private-key
SERVER_COUNTRIES=Switzerland

# --- amuled (mot de passe EC, partagé avec le crawler via config/local.yaml) ---
AMULE_EC_PASSWORD=changeme-ec-password
